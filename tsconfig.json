{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    // ESM + bundler resolution mirrors the root tsconfig (module "esnext",
    // moduleResolution "bundler"): the engine source uses extensionless relative
    // imports (`./planning`), so it type-checks IDENTICALLY here. NodeNext would
    // demand `.js` on every relative import — an invasive core rewrite the carve
    // deliberately avoided. `allowImportingTsExtensions` lets `build` emit while
    // the sources stay extensionless; `noEmit` is flipped off for the build run.
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noEmit": true
  },
  "include": ["**/*.ts", "headlines.json"],
  "exclude": ["node_modules", "dist"]
}

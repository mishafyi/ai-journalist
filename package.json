{
  "name": "ai-journalist",
  "version": "0.8.2",
  "description": "A domain-agnostic AI journalist / blog-generation engine behind hexagonal ports.",
  "type": "module",
  "license": "MIT",
  "author": "Zero G Talent",
  "main": "./index.ts",
  "keywords": [
    "ai",
    "llm",
    "blog",
    "content-generation",
    "journalism",
    "article-writing",
    "hexagonal-architecture",
    "ports-and-adapters",
    "openrouter",
    "firecrawl",
    "typescript",
    "esm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mishafyi/ai-journalist.git"
  },
  "bugs": {
    "url": "https://github.com/mishafyi/ai-journalist/issues"
  },
  "homepage": "https://github.com/mishafyi/ai-journalist#readme",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": "./index.ts",
    "./ports": "./ports.ts",
    "./pipeline": "./pipeline.ts",
    "./presets": "./presets/default.ts",
    "./sources": "./sources/index.ts",
    "./clients/openrouter-llm": "./clients/openrouter-llm.ts",
    "./clients/ollama-llm": "./clients/ollama-llm.ts",
    "./clients/firecrawl-search": "./clients/firecrawl-search.ts",
    "./clients/searxng-search": "./clients/searxng-search.ts",
    "./gates": "./gates.ts",
    "./discovery": "./discovery.ts",
    "./digest": "./digest.ts",
    "./section-writer": "./section-writer.ts",
    "./assembly": "./assembly.ts",
    "./run-context": "./run-context.ts",
    "./text": "./text.ts",
    "./news": "./news.ts",
    "./primitives": "./primitives.ts",
    "./gate": "./gate.ts",
    "./research": "./research.ts",
    "./testing/replay": "./testing/replay.ts",
    "./headlines.json": "./headlines.json"
  },
  "files": [
    "*.ts",
    "*.json",
    "presets",
    "sources",
    "clients",
    "testing",
    "examples",
    "README.md",
    "AGENTS.md",
    "CLAUDE.md",
    "CUSTOMIZING.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test:checks": "for f in $(find . -name '*.checks.ts' -not -path './node_modules/*'); do npx tsx \"$f\" || exit 1; done",
    "test:example": "vitest run",
    "test": "npm run test:checks && npm run test:example"
  },
  "dependencies": {
    "@openrouter/sdk": "^0.13.21",
    "date-fns": "^4.1.0",
    "firecrawl": "^4.25.2",
    "ollama": "^0.6.3",
    "p-limit": "^7.3.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "rss-parser": "^3.13.0",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.5.0",
    "tsx": "latest",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
